{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "image": "nodejs_20",
      "aptPkgs": []
    },
    "srcDir": "backend"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npm install && npm start"
  }
}
