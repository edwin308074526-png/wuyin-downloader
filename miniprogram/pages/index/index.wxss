.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 15rpx;
}

.platform-icons {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin: 30rpx 0;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.platform-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.2);
}

.platform-emoji {
  font-size: 40rpx;
}

.platform-name {
  font-size: 22rpx;
  color: #ffffff;
  margin-top: 10rpx;
}

.input-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 30rpx 0;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

.input-wrapper {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.url-input {
  flex: 1;
  height: 90rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 15rpx;
  padding: 0 25rpx;
  font-size: 28rpx;
  background: #f8f9fa;
}

.paste-btn {
  background: #667eea;
  color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.error-tip {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 20rpx;
  padding: 15rpx;
  background: #fff2f0;
  border-radius: 10rpx;
}

.parse-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.parse-btn.loading {
  background: #cccccc;
  box-shadow: none;
}

.parse-btn::after {
  border: none;
}

.tips-section {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 30rpx 0;
}

.tips-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tips-list {
  background: rgba(255,255,255,0.2);
  border-radius: 15rpx;
  padding: 25rpx;
}

.tip-item {
  color: #ffffff;
  font-size: 26rpx;
  margin: 15rpx 0;
  line-height: 1.5;
}

.tips-warning {
  color: #ffe066;
  font-size: 24rpx;
  margin-top: 20rpx;
  text-align: center;
}

.history-section {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 30rpx 0;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
}

.clear-btn {
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
}

.history-scroll {
  white-space: nowrap;
}

.history-list {
  display: flex;
  gap: 20rpx;
}

.history-item {
  position: relative;
  width: 160rpx;
  flex-shrink: 0;
}

.history-cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 15rpx;
  background: #e0e0e0;
}

.history-platform {
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.6);
  color: #ffffff;
  font-size: 20rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}
